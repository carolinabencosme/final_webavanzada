MAIL_PORT=1025
MAIL_SMTP_AUTH=false
MAIL_STARTTLS_ENABLE=false
MAIL_USERNAME=
MAIL_PASSWORD=

# Payment (mock mode by default)
PAYMENT_MOCK=true
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
