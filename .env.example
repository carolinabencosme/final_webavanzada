# JWT Secret
JWT_SECRET=bookstoreSecretKey2024bookstoreSecretKey2024XD

# PostgreSQL
DB_USER=postgres
DB_PASSWORD=postgres

# MongoDB
MONGO_DB=catalogdb

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Mail — Mailpit en Docker (sustituye MailHog): sin auth ni TLS
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_SMTP_AUTH=false
MAIL_STARTTLS_ENABLE=false
MAIL_USERNAME=
MAIL_PASSWORD=

# Payment (mock mode by default). Set PAYPAL_ENABLED=true and sandbox credentials to use PayPal.
PAYMENT_MOCK=true
PAYPAL_ENABLED=false
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Public URL of the SPA (welcome email login link). Docker: http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Zipkin (optional; docker-compose sets this for containers)
# ZIPKIN_URL=http://zipkin:9411/api/v2/spans
